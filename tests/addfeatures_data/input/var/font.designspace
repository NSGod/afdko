<?xml version='1.0' encoding='utf-8'?>
<designspace format="3">
    <axes>
        <!-- Weight axis: 200-900, default 400 -->
        <axis default="400" maximum="900" minimum="200" name="weight" tag="wght">
            <map input="200" output="0" />   <!-- ExtraLight -->
            <map input="300" output="145" /> <!-- Light -->
            <map input="400" output="394" /> <!-- Regular (default) -->
            <map input="600" output="594" /> <!-- Semibold -->
            <map input="700" output="823" /> <!-- Bold -->
            <map input="900" output="1000" /><!-- Black -->
        </axis>

        <!-- Optical Size axis: 8-60, default 20 -->
        <axis default="20" maximum="60" minimum="8" name="optical" tag="opsz" />
    </axes>

    <sources>
        <!-- Minimal source - just references the variable font itself -->
        <source familyname="Test Variable Font" filename="font.cff2">
            <lib copy="1"/>
            <info copy="1" />
            <location>
                <dimension name="weight" xvalue="394" />
                <dimension name="optical" xvalue="20" />
            </location>
        </source>
    </sources>

    <instances>
        <!-- Regular instance at default location -->
        <instance postscriptfontname="TestFont-Regular" stylename="Regular">
            <location>
                <dimension name="weight" xvalue="394" />
                <dimension name="optical" xvalue="20" />
            </location>
            <kerning />
            <info />
        </instance>

        <!-- Bold instance for testing -->
        <instance postscriptfontname="TestFont-Bold" stylename="Bold">
            <location>
                <dimension name="weight" xvalue="823" />
                <dimension name="optical" xvalue="20" />
            </location>
            <kerning />
            <info />
        </instance>

        <!-- Light instance for testing -->
        <instance postscriptfontname="TestFont-Light" stylename="Light">
            <location>
                <dimension name="weight" xvalue="145" />
                <dimension name="optical" xvalue="20" />
            </location>
            <kerning />
            <info />
        </instance>
    </instances>
</designspace>
